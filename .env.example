# =============================================================================
# VoxCPM Desktop Pet - 环境变量配置模板
# =============================================================================
# 使用方法：
#   1. 复制本文件并重命名为 .env  (cp .env.example .env)
#   2. 把下面的占位符替换成你自己的真实值
#   3. .env 文件已被 .gitignore 忽略，不会被提交到 GitHub
#
# 获取 API Key：
#   - 智谱 AI (推荐，兼容 Anthropic 协议): https://open.bigmap.cn/
#     注册后在控制台 → API Keys 页面创建 key
#   - 也可改用其他兼容 Anthropic 协议的服务，只需改 BASE_URL
# =============================================================================

# ---------- 必填：AI 服务认证 ----------
# AI API Key (从服务商控制台获取，不要带 Bearer 前缀)
AI_API_KEY=your_api_key_here

# AI 服务的基础 URL
# 智谱 AI (GLM) 兼容 OpenAI 协议:
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 使用的模型名称 (例如: glm-5.2, glm-4.6, glm-4.5)
AI_MODEL=glm-5.2


# ---------- 必填：Anthropic 协议配置 (桌宠实际使用的是这套) ----------
# 智谱 AI 也提供 Anthropic 兼容协议，推荐使用，与 Claude SDK 直连互通
ANTHROPIC_AUTH_TOKEN=your_api_key_here

# Anthropic 兼容协议的基础 URL
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Sonnet 类模型映射 (实际请求时使用的模型)
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.2


# ---------- 可选：调用参数 ----------
# 请求超时时间 (毫秒), 默认 300000 (5 分钟)
API_TIMEOUT_MS=300000

# 单次响应最大 token 数, 默认 512
AI_MAX_TOKENS=512

# 采样温度 (0~2, 越大越发散), 默认 0.8
AI_TEMPERATURE=0.8

# Anthropic 协议版本号
ANTHROPIC_VERSION=2023-06-01

# 系统提示词 (定义 AI 的角色与风格)
AI_SYSTEM_PROMPT=你是一个中文AI桌宠，语气可爱、简短、像陪伴型助手。回答不要太长。
